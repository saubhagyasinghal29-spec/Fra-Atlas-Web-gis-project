# ---- core ----
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=generate-a-50-char-random-string
DJANGO_ALLOWED_HOSTS=api.fra-atlas.gov.in
CSRF_TRUSTED_ORIGINS=https://api.fra-atlas.gov.in
LOG_LEVEL=INFO

# ---- datastores ----
DATABASE_URL=postgis://fra:CHANGE@postgis:5432/fra_atlas
REDIS_URL=redis://redis:6379/0
USE_GIS=1

# ---- secrets (use a real secrets manager / KMS) ----
AUDIT_LOG_SECRET=rotate-quarterly
ENCRYPTION_ACTIVE_VERSION=1
ENCRYPTION_KEY_V1=generate-with-Fernet.generate_key()

# ---- documents subsystem ----
STORAGE_BACKEND=s3            # local | s3
AWS_STORAGE_BUCKET_NAME=fra-atlas-documents
AWS_S3_REGION_NAME=ap-south-1
AV_SCANNER=clamav             # noop | clamav
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
OCR_ENGINE=tesseract          # noop | tesseract

# ---- gunicorn ----
GUNICORN_WORKERS=4
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=60
